{
  "name": "expresstypescriptstarter",
  "version": "1.0.0",
  "description": "\"A starter express typescript server\"",
  "license": "ISC",
  "author": "psycho",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}